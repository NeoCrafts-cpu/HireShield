# ==========================
# HireShield Environment Variables
# ==========================

# Deployer private key (without 0x prefix)
PRIVATE_KEY=your_private_key_here

# Sepolia RPC URL (e.g., from Alchemy or Infura)
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

# CoFHE trusted node address (for FHE computation authorization)
COFHE_NODE_ADDRESS=0x0000000000000000000000000000000000000000

# Privara escrow contract address on Sepolia (optional, defaults to zero address)
PRIVARA_ESCROW_ADDRESS=0x0000000000000000000000000000000000000000

# ==========================
# Frontend Environment Variables (in frontend/.env)
# ==========================

# WalletConnect project ID (get one at https://cloud.walletconnect.com/)
VITE_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# Privara / Reineira API key
VITE_PRIVARA_API_KEY=your_privara_api_key

# Deployed contract addresses (set after deployment)
VITE_HIRESHIELD_ADDRESS=0x0000000000000000000000000000000000000000
VITE_ESCROW_ADDRESS=0x0000000000000000000000000000000000000000
